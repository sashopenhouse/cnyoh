# Supabase Configuration
# Get these from: https://app.supabase.com → Project Settings → API

# Public anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose in browser — server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Slack Webhook URL
# Setup: https://api.slack.com/apps → Create App → Incoming Webhooks → Add New Webhook
# Paste the webhook URL below (keep this secret — server-side only)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
